# Server
PORT=4000
NODE_ENV=development

# PostgreSQL (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/student_dashboard_?schema=public"

# JWT  (access token: 15m, refresh token: 7d)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
REFRESH_TOKEN_SECRET=your-super-secret-refresh-key-change-in-production

# CORS
CORS_ORIGIN=http://localhost:5173

# Google Sign-In — required for POST /api/auth/google (same value as frontend VITE_GOOGLE_CLIENT_ID)
# GCP: APIs & Services → Credentials → OAuth 2.0 Client ID (type: Web application) → Client ID
# Authorized JavaScript origins must include your dev origin (e.g. http://localhost:5173 and http://127.0.0.1:5173)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# VTOP Sync (AES-256 key — generate with: openssl rand -hex 32)

