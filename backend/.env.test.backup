# Test database — use a separate DB from development
# Create with: createdb student_dashboard_test
# Copy from .env and change the database name to student_dashboard_test
TEST_DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/student_dashboard_test?schema=public"
# Fallback if TEST_DATABASE_URL not set
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/student_dashboard_test?schema=public"

# JWT (required for auth)
JWT_SECRET=test-jwt-secret-do-not-use-in-production
REFRESH_TOKEN_SECRET=test-refresh-secret-do-not-use-in-production

NODE_ENV=test
CORS_ORIGIN=http://localhost:5173
