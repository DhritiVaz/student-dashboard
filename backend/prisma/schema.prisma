generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum AssignmentStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  GRADED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum CalendarEventType {
  CLASS
  EXAM
  DEADLINE
  PERSONAL
}

// ─── Core Models ──────────────────────────────────────────────────────────────

model User {
  id         String    @id @default(cuid())
  email      String    @unique
  password   String? // null for Google-only accounts
  name       String
  googleSub  String?   @unique
  imageUrl   String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  semesters      Semester[]
  tasks          Task[]
  calendarEvents CalendarEvent[]
  refreshTokens  RefreshToken[]
  vtopAttendance VtopAttendance[]
  vtopGrades     VtopGrade[]
  vtopAcademicEvents VtopAcademicEvent[] 
  vtopTimetable VtopTimetable[]
  vtopMarks     VtopMark[]
  vtopStudentMetrics VtopStudentMetrics?
  vtopSemesterMetrics VtopSemesterMetrics[]
  studentFiles      StudentFile[]

  @@index([email])
  @@index([deletedAt])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Semester {
  id        String    @id @default(cuid())
  userId    String
  name      String
  startDate DateTime
  endDate   DateTime
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courses Course[]

  @@index([userId])
  @@index([deletedAt])
}

model Course {
  id          String    @id @default(cuid())
  semesterId  String
  name        String
  code        String?
  instructor  String?
  description String?
  color       String?
  credits     Float?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  semester       Semester        @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  assignments    Assignment[]
  notes          Note[]
  calendarEvents CalendarEvent[]
  tasks          Task[]
  studentFiles   StudentFile[]

  @@index([semesterId])
  @@index([deletedAt])
}

/// User-uploaded documents (PDFs, slides, etc.) with optional course link.
model StudentFile {
  id           String    @id @default(cuid())
  userId       String
  title        String
  description  String?
  storedName   String
  originalName String
  mimeType     String?
  sizeBytes    Int
  courseId     String?
  category     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([courseId])
  @@index([deletedAt])
}

model Assignment {
  id          String           @id @default(cuid())
  courseId    String
  title       String
  description String?
  dueDate     DateTime?
  weight      Float            @default(0)
  isSubmitted Boolean          @default(false)
  status      AssignmentStatus @default(NOT_STARTED)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?

  course Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  grades Grade[]
  tasks  Task[]

  @@index([courseId])
  @@index([dueDate])
  @@index([status])
  @@index([deletedAt])
}

model Grade {
  id           String    @id @default(cuid())
  assignmentId String    @unique
  score        Float
  maxScore     Float
  feedback     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@index([assignmentId])
}

model Note {
  id        String    @id @default(cuid())
  courseId  String
  title     String
  content   String
  tags      String[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([deletedAt])
}

model CalendarEvent {
  id          String            @id @default(cuid())
  userId      String
  courseId    String?
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime
  isAllDay    Boolean           @default(false)
  color       String?
  type        CalendarEventType @default(CLASS)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([courseId])
  @@index([startDate])
  @@index([endDate])
  @@index([deletedAt])
}

model Task {
  id           String       @id @default(cuid())
  userId       String
  courseId     String?
  assignmentId String?
  title        String
  description  String?
  dueDate      DateTime?
  isCompleted  Boolean      @default(false)
  priority     TaskPriority @default(MEDIUM)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     Course?     @relation(fields: [courseId], references: [id], onDelete: SetNull)
  assignment Assignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([courseId])
  @@index([assignmentId])
  @@index([dueDate])
  @@index([isCompleted])
  @@index([deletedAt])
}

model VtopAttendance {
  id                String   @id @default(cuid())
  userId            String
  courseCode        String
  courseName        String
  courseType        String?
  conducted         Int
  attended          Int
  attendancePercent Float
  syncedAt          DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseCode])
  @@index([userId])
}

model VtopGrade {
  id            String   @id @default(cuid())
  userId        String
  semesterLabel String   @default("") // normalized section title from grade history; "" rare, use "Unknown" when missing
  courseCode    String
  courseName    String
  credits       Float?
  grade         String?
  gradePoint    Float?
  faculty       String?
  slot          String?
  category      String? // e.g. programme / university elective when present in table
  syncedAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, semesterLabel, courseCode])
  @@index([userId])
  @@index([userId, semesterLabel])
}

model VtopStudentMetrics {
  id             String   @id @default(cuid())
  userId         String   @unique
  cgpaFromPortal Float?
  syncedAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VtopSemesterMetrics {
  id             String   @id @default(cuid())
  userId         String
  semesterLabel  String
  gpaFromPortal  Float?
  sortIndex      Int      @default(0)
  syncedAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, semesterLabel])
  @@index([userId])
}

model VtopMark {
  id         String   @id @default(cuid())
  userId     String
  courseCode String
  component  String // e.g. "CAT-I", "Internal"
  scored     Float?
  maxScore   Float?
  syncedAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseCode, component])
  @@index([userId])
  @@index([userId, courseCode])
}

model VtopAcademicEvent {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  eventType String   // "Holiday", "CAT - I", "Instructional Day", etc.
  label     String   // "(Winter Vacation)", "(Working Day)", etc.
  syncedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model VtopTimetable {
  id             String   @id @default(cuid())
  userId         String
  // VTOP semester dropdown value (e.g. CH20252605) for this timetable fetch
  semesterSubId  String   @default("")
  // Human label from the same dropdown (e.g. Winter Semester 2025-26)
  semesterLabel  String?
  courseCode     String
  courseName     String
  courseType     String   // "TH", "LO", "ELA", "ETH", "SS"
  slot           String   // "A1", "L11", etc.
  venue          String
  dayOfWeek      Int      // 0=Sun, 1=Mon, 2=Tue, 3=Wed, 4=Thu, 5=Fri, 6=Sat
  startTime      String   // "08:00"
  endTime        String   // "08:50"
  syncedAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, semesterSubId, slot, dayOfWeek])
  @@index([userId])
  @@index([userId, semesterSubId])
}