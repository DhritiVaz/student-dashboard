# Vite env vars must be prefixed with VITE_
VITE_API_URL=http://localhost:4000/api

# Same OAuth 2.0 Web Client ID as backend GOOGLE_CLIENT_ID. If gsi/status returns 403, add this exact
# page origin (localhost vs 127.0.0.1) under Authorized JavaScript origins in Google Cloud Console.
VITE_GOOGLE_CLIENT_ID=
